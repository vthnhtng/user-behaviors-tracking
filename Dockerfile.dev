FROM eclipse-temurin:17-jdk-alpine
WORKDIR /app

# Install bash for Maven wrapper
RUN apk add --no-cache bash

# Copy Maven wrapper
COPY .mvn/ .mvn/
COPY mvnw pom.xml ./

# Download dependencies
RUN ./mvnw dependency:go-offline -B

# Copy source
COPY src ./src

EXPOSE 8080
EXPOSE 5005  # Debug port

CMD ["./mvnw", "spring-boot:run"]